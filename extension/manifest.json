{
  "manifest_version": 3,
  "name": "GH PR checkout (gh-ocd)",
  "version": "1.0.0",
  "description": "Replaces GitHub's copy-head-branch with fetch + checkout via a local helper.",
  "permissions": ["storage", "scripting", "activeTab", "clipboardWrite"],
  "host_permissions": ["https://github.com/*", "http://127.0.0.1:17373/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*/*/pull/*",
        "https://github.com/*/*/pull/*/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html"
}
